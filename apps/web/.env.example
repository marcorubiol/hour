# Local-dev env vars for `pnpm dev`. Copy this file to `.env` and fill in the
# values from `wrangler.toml [vars]` (they are public, same values shipped to
# the browser at runtime). The .env file is gitignored.
#
# Why this duplication: `vite dev` does NOT read `wrangler.toml [vars]` for
# `$env/dynamic/public`. Production (`wrangler deploy`) reads from wrangler.toml
# directly — no .env needed there.
#
# Optional: PUBLIC_SENTRY_DSN to activate Sentry in dev (hooks are wired but
# no-op without DSN). PUBLIC_SENTRY_ENV defaults to "phase0".

PUBLIC_SUPABASE_URL=""
PUBLIC_SUPABASE_ANON_KEY=""

# PUBLIC_SENTRY_DSN=""
# PUBLIC_SENTRY_ENV="phase0-dev"
