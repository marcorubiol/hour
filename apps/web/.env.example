# Local-dev + build env vars for SvelteKit. Copy this file to `.env` and fill
# in the values. The .env file is gitignored.
#
# Supabase (PUBLIC_SUPABASE_*): mirror the values from `wrangler.toml [vars]`.
# Production reads from wrangler.toml directly; this copy is what `vite dev`
# sees AND what `vite build` uses for `$env/static/public` ($env/dynamic/public
# falls back to wrangler.toml in deployed Workers).
#
# Sentry (PUBLIC_SENTRY_*): only here, NOT in wrangler.toml. SvelteKit's
# `$env/static/public` bakes the DSN into the JS bundle at build time, so
# `wrangler deploy` ships the DSN already inlined. Sentry DSNs are public-safe
# by design. Leave PUBLIC_SENTRY_DSN empty to disable Sentry — both hooks
# initialise with enabled:false and no events ship.
#
# Optional: SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT enable source-map
# upload to Sentry on `vite build` so server stack traces resolve to original
# .ts/.svelte. Without them, the upload step is silently skipped. The auth
# token must stay secret; org and project are slugs.

PUBLIC_SUPABASE_URL=""
PUBLIC_SUPABASE_ANON_KEY=""

PUBLIC_SENTRY_DSN=""
PUBLIC_SENTRY_ENV="phase0"

# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
