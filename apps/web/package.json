{
  "name": "web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev",
    "deploy": "node ../../scripts/assert-clean-tree.mjs && vite build && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "cf-typegen": "wrangler types",
    "test:install": "playwright install --with-deps chromium",
    "test:smoke": "playwright test",
    "test:unit": "vitest run --project server --project client",
    "test:unit:watch": "vitest --project server --project client",
    "test:rls": "vitest run --project rls"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.54.0",
    "@supabase/realtime-js": "^2.105.4",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tanstack/svelte-query": "^5.62.0",
    "idb": "^8.0.3",
    "partyserver": "^0.5.5",
    "svelte": "^5.56.6",
    "valibot": "^1.0.0",
    "workbox-window": "^7.4.1",
    "y-indexeddb": "^9.0.12",
    "y-partyserver": "^2.2.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.1.1",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.103.0"
  }
}
