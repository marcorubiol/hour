---
import Base from "../layouts/Base.astro";

export const prerender = false;
---

<Base title="Hour — Difusión 2026-27">
  <header class="app-header">
    <h1 class="app-header__title">
      Hour <span class="app-header__scope">/ Difusión 2026-27</span>
    </h1>
    <button class="btn btn--ghost" id="logout-btn">Salir</button>
  </header>

  <div class="status-bar" id="status-bar">
    <span>Cargando...</span>
  </div>

  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Organización</th>
          <th>Ubicación</th>
          <th>Estado</th>
          <th>Próxima acción</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>

  <div class="msg" id="msg" hidden></div>

  <div class="pagination" id="pagination" hidden>
    <button class="btn btn--ghost" id="prev-btn">Anterior</button>
    <button class="btn btn--ghost" id="next-btn">Siguiente</button>
  </div>

  <style>
    @layer components {
      /* ---- App header ---- */
      .app-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-m);
        padding: var(--space-m) var(--gutter);
        border-block-end: var(--divider-light);
      }

      .app-header__title {
        font-size: var(--text-l);
        font-weight: 600;
        letter-spacing: var(--letter-spacing-tight);
      }

      .app-header__scope {
        color: var(--text-dark-muted);
        font-weight: 400;
      }

      /* ---- Generic ghost button ---- */
      .btn {
        font-family: var(--btn-font-family);
        font-size: var(--text-s);
        line-height: var(--btn-line-height);
        padding: var(--space-xs) var(--space-s);
        border-radius: var(--btn-border-radius);
        border: var(--border-width) var(--border-style) transparent;
        cursor: pointer;
        transition:
          color var(--transition-duration),
          border-color var(--transition-duration),
          background var(--transition-duration);
      }

      .btn--ghost {
        color: var(--text-dark-muted);
        border-color: var(--border-color-dark);
        background: var(--bg-ultra-light);
      }
      .btn--ghost:hover {
        color: var(--heading-color);
        border-color: var(--neutral-semi-light);
        background: var(--bg-light);
      }
      .btn--ghost:focus-visible {
        outline: var(--focus-width) solid var(--focus-color);
        outline-offset: var(--focus-offset);
      }
      .btn:disabled {
        opacity: var(--disabled-opacity);
        cursor: not-allowed;
      }

      /* ---- Status bar ---- */
      .status-bar {
        display: flex;
        align-items: center;
        gap: var(--space-m);
        padding: var(--space-s) var(--gutter);
        border-block-end: var(--divider-light);
        font-size: var(--text-s);
        color: var(--text-dark-muted);
        flex-wrap: wrap;
      }

      .status-bar__count {
        color: var(--heading-color);
        font-weight: 500;
      }

      /* ---- Data table ---- */
      .table-wrap {
        overflow-x: auto;
        padding-inline: var(--gutter);
      }

      .data-table {
        inline-size: 100%;
        border-collapse: collapse;
        min-inline-size: 44rem;
      }

      .data-table th {
        text-align: start;
        padding: var(--space-s);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--text-dark-muted);
        font-weight: 500;
        border-block-end: var(--divider-light);
        white-space: nowrap;
      }

      .data-table td {
        padding: var(--space-s);
        border-block-end: var(--divider-light);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-inline-size: 16rem;
      }

      .data-table tr:hover td {
        background: var(--bg-light);
      }

      .cell--name {
        font-weight: 500;
        color: var(--heading-color);
      }
      .cell--muted {
        color: var(--text-dark-muted);
      }
      .cell--meta {
        color: var(--text-dark-muted);
        font-size: var(--text-s);
      }

      /* ---- Status badge — engagement.status domain ---- */
      .badge {
        display: inline-block;
        padding: var(--space-xs) var(--space-s);
        border-radius: var(--radius-circle);
        font-size: var(--text-xs);
        font-weight: 500;
        line-height: 1.4;
      }

      .badge--contacted {
        background: var(--info-ultra-light);
        color: var(--info-ultra-dark);
      }
      .badge--in-conversation {
        background: var(--warning-ultra-light);
        color: var(--warning-ultra-dark);
      }
      .badge--hold {
        background: var(--neutral-ultra-light);
        color: var(--neutral-dark);
      }
      .badge--confirmed {
        background: var(--success-ultra-light);
        color: var(--success-ultra-dark);
      }
      .badge--declined {
        background: var(--danger-ultra-light);
        color: var(--danger-ultra-dark);
      }
      .badge--dormant {
        background: var(--neutral-ultra-light);
        color: var(--neutral-semi-dark);
        opacity: 0.75;
      }
      .badge--recurring {
        background: var(--primary-ultra-light);
        color: var(--primary-ultra-dark);
      }

      /* ---- Loading / empty / error message ---- */
      .msg {
        text-align: center;
        padding-block: var(--space-xxl);
        padding-inline: var(--gutter);
        color: var(--text-dark-muted);
      }
      .msg--error {
        color: var(--danger-dark);
      }

      /* ---- Pagination ---- */
      .pagination {
        display: flex;
        justify-content: center;
        gap: var(--space-s);
        padding: var(--space-m) var(--gutter);
      }
    }
  </style>

  <script>
    const LIMIT = 50;
    let offset = 0;
    let total = 0;

    const jwt = localStorage.getItem("hour_jwt");
    if (!jwt) {
      window.location.replace("/login");
    }

    const tbody = document.getElementById("tbody");
    const msgEl = document.getElementById("msg");
    const statusBar = document.getElementById("status-bar");
    const pagination = document.getElementById("pagination");
    const prevBtn = document.getElementById("prev-btn");
    const nextBtn = document.getElementById("next-btn");

    const STATUS_LABELS = {
      contacted: "Contactado",
      in_conversation: "En conversación",
      hold: "Hold",
      confirmed: "Confirmado",
      declined: "Declinado",
      dormant: "Dormant",
      recurring: "Recurrente",
    };

    function showMsg(text, isError = false) {
      msgEl.textContent = text;
      msgEl.className = isError ? "msg msg--error" : "msg";
      msgEl.hidden = false;
      tbody.innerHTML = "";
    }

    function formatDate(iso) {
      if (!iso) return "—";
      const d = new Date(iso);
      return d.toLocaleDateString("es-ES", { day: "2-digit", month: "short" });
    }

    function renderRow(item) {
      const person = item.person || {};
      const loc = [person.city, person.country].filter(Boolean).join(", ");
      const status = item.status || "contacted";
      const badgeMod = status.replace(/_/g, "-");
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="cell--name">${esc(person.full_name || "—")}</td>
        <td class="cell--muted">${esc(person.organization_name || "—")}</td>
        <td class="cell--meta">${esc(loc || "—")}</td>
        <td><span class="badge badge--${badgeMod}">${esc(STATUS_LABELS[status] || status)}</span></td>
        <td class="cell--meta">${formatDate(item.next_action_at)}</td>
      `;
      return tr;
    }

    function esc(s) {
      const d = document.createElement("div");
      d.textContent = s;
      return d.innerHTML;
    }

    async function load() {
      msgEl.hidden = true;
      tbody.innerHTML = "";
      statusBar.innerHTML = "<span>Cargando...</span>";

      try {
        const url = `/api/engagements?status=any&project_slug=mamemi&season=2026-27&limit=${LIMIT}&offset=${offset}`;
        const res = await fetch(url, {
          headers: { Authorization: `Bearer ${jwt}` },
        });

        if (res.status === 401) {
          localStorage.removeItem("hour_jwt");
          localStorage.removeItem("hour_refresh");
          localStorage.removeItem("hour_expires_at");
          window.location.replace("/login");
          return;
        }

        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body.detail || body.error || `Error ${res.status}`);
        }

        const data = await res.json();
        total = data.total || 0;

        statusBar.innerHTML = `
          <span class="status-bar__count">${total} contactos</span>
          <span>Mostrando ${offset + 1}-${Math.min(offset + LIMIT, total)}</span>
        `;

        if (data.items.length === 0) {
          showMsg("Sin resultados.");
          return;
        }

        for (const item of data.items) {
          tbody.appendChild(renderRow(item));
        }

        if (total > LIMIT) {
          pagination.hidden = false;
          prevBtn.disabled = offset === 0;
          nextBtn.disabled = offset + LIMIT >= total;
        } else {
          pagination.hidden = true;
        }
      } catch (err) {
        showMsg(err.message, true);
      }
    }

    prevBtn.addEventListener("click", () => {
      offset = Math.max(0, offset - LIMIT);
      load();
    });
    nextBtn.addEventListener("click", () => {
      offset += LIMIT;
      load();
    });

    document.getElementById("logout-btn").addEventListener("click", () => {
      localStorage.removeItem("hour_jwt");
      localStorage.removeItem("hour_refresh");
      localStorage.removeItem("hour_expires_at");
      window.location.replace("/login");
    });

    load();
  </script>
</Base>
