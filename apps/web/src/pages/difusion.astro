---
import Base from "../layouts/Base.astro";

export const prerender = false;
---

<Base title="Hour — Difusión 2026-27">
  <header class="app-header">
    <h1 class="app-header__title">
      Hour <span class="app-header__scope">/ Difusión 2026-27</span>
    </h1>
    <button class="btn btn--ghost" id="logout-btn">Salir</button>
  </header>

  <div class="status-bar" id="status-bar">
    <span>Cargando...</span>
  </div>

  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Organización</th>
          <th>Ubicación</th>
          <th>Estado</th>
          <th>Próxima acción</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>
  </div>

  <div class="msg" id="msg" hidden></div>

  <div class="pagination" id="pagination" hidden>
    <button class="btn btn--ghost" id="prev-btn">Anterior</button>
    <button class="btn btn--ghost" id="next-btn">Siguiente</button>
  </div>

  <style>
    @layer components {
      /* ---- App header ---- */
      .app-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-m);
        padding: var(--space-m) var(--gutter);
        border-block-end: var(--border-width) solid var(--border-subtle);
      }

      .app-header__title {
        font-size: var(--text-l);
        font-weight: 600;
        letter-spacing: var(--letter-spacing-tight);
      }

      .app-header__scope {
        color: var(--ink-muted);
        font-weight: 400;
      }

      /* ---- Generic ghost button (reused header + pagination) ---- */
      .btn {
        font-family: inherit;
        font-size: var(--text-s);
        padding: var(--space-xs) var(--space-s);
        border-radius: var(--radius-s);
        border: var(--border-width) solid transparent;
        cursor: pointer;
        transition:
          color var(--transition-fast),
          border-color var(--transition-fast),
          background var(--transition-fast);
      }

      .btn--ghost {
        color: var(--ink-muted);
        border-color: var(--border-default);
        background: var(--surface-1);
      }
      .btn--ghost:hover {
        color: var(--ink-strong);
        border-color: var(--border-strong);
        background: var(--surface-2);
      }
      .btn--ghost:focus-visible {
        outline: var(--focus-ring-width) solid var(--focus-ring-color);
        outline-offset: var(--focus-ring-offset);
      }
      .btn:disabled {
        opacity: var(--disabled-opacity);
        cursor: not-allowed;
      }

      /* ---- Status bar ---- */
      .status-bar {
        display: flex;
        align-items: center;
        gap: var(--space-m);
        padding: var(--space-s) var(--gutter);
        border-block-end: var(--border-width) solid var(--border-subtle);
        font-size: var(--text-s);
        color: var(--ink-muted);
        flex-wrap: wrap;
      }

      .status-bar__count {
        color: var(--ink-strong);
        font-weight: 500;
      }

      /* ---- Data table ---- */
      .table-wrap {
        overflow-x: auto;
        padding-inline: var(--gutter);
      }

      .data-table {
        inline-size: 100%;
        border-collapse: collapse;
        min-inline-size: 44rem;
      }

      .data-table th {
        text-align: start;
        padding: var(--space-s) var(--space-s);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: var(--letter-spacing-wider);
        color: var(--ink-muted);
        font-weight: 500;
        border-block-end: var(--border-width) solid var(--border-subtle);
        white-space: nowrap;
      }

      .data-table td {
        padding: var(--space-s) var(--space-s);
        border-block-end: var(--border-width) solid var(--border-subtle);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-inline-size: 16rem;
      }

      .data-table tr:hover td {
        background: var(--surface-2);
      }

      .cell--name {
        font-weight: 500;
        color: var(--ink-strong);
      }
      .cell--muted {
        color: var(--ink-muted);
      }
      .cell--meta {
        color: var(--ink-muted);
        font-size: var(--text-s);
      }

      /* ---- Status badge ---- */
      .badge {
        display: inline-block;
        padding: var(--space-xs) var(--space-s);
        border-radius: var(--radius-pill);
        font-size: var(--text-xs);
        font-weight: 500;
        letter-spacing: var(--letter-spacing-default);
        line-height: 1.4;
      }

      .badge--positive {
        background: var(--status-positive-bg);
        color: var(--status-positive-fg);
      }
      .badge--warning {
        background: var(--status-warning-bg);
        color: var(--status-warning-fg);
      }
      .badge--negative {
        background: var(--status-negative-bg);
        color: var(--status-negative-fg);
      }
      .badge--neutral {
        background: var(--status-neutral-bg);
        color: var(--status-neutral-fg);
      }
      .badge--info {
        background: var(--status-info-bg);
        color: var(--status-info-fg);
      }
      .badge--accent {
        background: var(--status-accent-bg);
        color: var(--status-accent-fg);
      }
      .badge--subtle {
        opacity: 0.65;
      }

      /* ---- Loading / empty / error message ---- */
      .msg {
        text-align: center;
        padding-block: var(--space-xxl);
        padding-inline: var(--gutter);
        color: var(--ink-muted);
      }
      .msg--error {
        color: var(--danger-dark);
      }

      /* ---- Pagination ---- */
      .pagination {
        display: flex;
        justify-content: center;
        gap: var(--space-s);
        padding: var(--space-m) var(--gutter);
      }
    }
  </style>

  <script>
    const LIMIT = 50;
    let offset = 0;
    let total = 0;

    const jwt = localStorage.getItem("hour_jwt");
    if (!jwt) {
      window.location.replace("/login");
    }

    const tbody = document.getElementById("tbody");
    const msgEl = document.getElementById("msg");
    const statusBar = document.getElementById("status-bar");
    const pagination = document.getElementById("pagination");
    const prevBtn = document.getElementById("prev-btn");
    const nextBtn = document.getElementById("next-btn");

    const STATUS_LABELS = {
      contacted: "Contactado",
      in_conversation: "En conversación",
      hold: "Hold",
      confirmed: "Confirmado",
      declined: "Declinado",
      dormant: "Dormant",
      recurring: "Recurrente",
    };

    /* Domain → semantic mapping. Decoupled from token shades on purpose:
       same vocabulary ('positive', 'warning', etc.) reusable for invoices,
       gigs, anything else with state. Subtle tone for dormant. */
    const STATUS_VARIANT = {
      contacted: "info",
      in_conversation: "warning",
      hold: "neutral",
      confirmed: "positive",
      declined: "negative",
      dormant: "neutral subtle",
      recurring: "accent",
    };

    function showMsg(text, isError = false) {
      msgEl.textContent = text;
      msgEl.className = isError ? "msg msg--error" : "msg";
      msgEl.hidden = false;
      tbody.innerHTML = "";
    }

    function formatDate(iso) {
      if (!iso) return "—";
      const d = new Date(iso);
      return d.toLocaleDateString("es-ES", { day: "2-digit", month: "short" });
    }

    function badgeClass(status) {
      const variants = (STATUS_VARIANT[status] || "neutral").split(" ");
      return variants.map((v) => `badge--${v}`).join(" ");
    }

    function renderRow(item) {
      const person = item.person || {};
      const loc = [person.city, person.country].filter(Boolean).join(", ");
      const status = item.status || "contacted";
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td class="cell--name">${esc(person.full_name || "—")}</td>
        <td class="cell--muted">${esc(person.organization_name || "—")}</td>
        <td class="cell--meta">${esc(loc || "—")}</td>
        <td><span class="badge ${badgeClass(status)}">${esc(STATUS_LABELS[status] || status)}</span></td>
        <td class="cell--meta">${formatDate(item.next_action_at)}</td>
      `;
      return tr;
    }

    function esc(s) {
      const d = document.createElement("div");
      d.textContent = s;
      return d.innerHTML;
    }

    async function load() {
      msgEl.hidden = true;
      tbody.innerHTML = "";
      statusBar.innerHTML = "<span>Cargando...</span>";

      try {
        const url = `/api/engagements?status=any&project_slug=mamemi&season=2026-27&limit=${LIMIT}&offset=${offset}`;
        const res = await fetch(url, {
          headers: { Authorization: `Bearer ${jwt}` },
        });

        if (res.status === 401) {
          localStorage.removeItem("hour_jwt");
          localStorage.removeItem("hour_refresh");
          localStorage.removeItem("hour_expires_at");
          window.location.replace("/login");
          return;
        }

        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(body.detail || body.error || `Error ${res.status}`);
        }

        const data = await res.json();
        total = data.total || 0;

        statusBar.innerHTML = `
          <span class="status-bar__count">${total} contactos</span>
          <span>Mostrando ${offset + 1}-${Math.min(offset + LIMIT, total)}</span>
        `;

        if (data.items.length === 0) {
          showMsg("Sin resultados.");
          return;
        }

        for (const item of data.items) {
          tbody.appendChild(renderRow(item));
        }

        if (total > LIMIT) {
          pagination.hidden = false;
          prevBtn.disabled = offset === 0;
          nextBtn.disabled = offset + LIMIT >= total;
        } else {
          pagination.hidden = true;
        }
      } catch (err) {
        showMsg(err.message, true);
      }
    }

    prevBtn.addEventListener("click", () => {
      offset = Math.max(0, offset - LIMIT);
      load();
    });
    nextBtn.addEventListener("click", () => {
      offset += LIMIT;
      load();
    });

    document.getElementById("logout-btn").addEventListener("click", () => {
      localStorage.removeItem("hour_jwt");
      localStorage.removeItem("hour_refresh");
      localStorage.removeItem("hour_expires_at");
      window.location.replace("/login");
    });

    load();
  </script>
</Base>
