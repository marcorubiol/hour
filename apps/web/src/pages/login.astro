---
import Base from "../layouts/Base.astro";

export const prerender = false;
const env = Astro.locals.runtime.env;
const supabaseUrl = env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = env.PUBLIC_SUPABASE_ANON_KEY;
---

<Base title="Hour — Login">
  <main class="login">
    <div class="login__card">
      <h1 class="login__heading">Hour</h1>
      <p class="login__subtitle">Phase 0</p>

      <form class="login__form" id="login-form">
        <label class="login__label" for="email">Email</label>
        <input
          class="login__input"
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          autofocus
        />

        <label class="login__label" for="password">Password</label>
        <input
          class="login__input"
          type="password"
          id="password"
          name="password"
          required
          autocomplete="current-password"
        />

        <p class="login__error" id="error-msg"></p>

        <button class="login__submit" type="submit" id="submit-btn">
          Entrar
        </button>
      </form>
    </div>
  </main>

  <style>
    @layer components {
      .login {
        min-block-size: 100dvh;
        display: grid;
        place-items: center;
        padding: var(--space-l);
      }

      .login__card {
        inline-size: 100%;
        max-inline-size: 22rem;
      }

      .login__heading {
        font-size: var(--h2);
        margin-block-end: var(--space-xs);
      }

      .login__subtitle {
        color: var(--text-dark-muted);
        font-size: var(--text-s);
        margin-block-end: var(--space-xl);
      }

      .login__form {
        display: grid;
        gap: var(--space-s);
      }

      .login__label {
        font-size: var(--text-xs);
        color: var(--text-dark-muted);
        text-transform: uppercase;
        letter-spacing: var(--letter-spacing-wide);
        margin-block-end: calc(var(--space-xs) * -1);
      }

      .login__input {
        inline-size: 100%;
        padding: var(--space-s) var(--space-m);
        background: var(--bg-ultra-light);
        border: var(--border);
        border-radius: var(--radius-s);
        color: var(--heading-color);
        font-size: var(--text-m);
        outline: none;
        transition: border-color var(--transition-duration);
      }

      .login__input:hover {
        border-color: var(--neutral-semi-light);
      }

      .login__input:focus-visible {
        border-color: var(--primary);
        outline: var(--focus-width) solid var(--focus-color);
        outline-offset: 1px;
      }

      .login__error {
        color: var(--danger-dark);
        font-size: var(--text-s);
        min-block-size: var(--text-s);
        display: none;
      }
      .login__error--visible {
        display: block;
      }

      .login__submit {
        margin-block-start: var(--space-s);
        padding: var(--btn-padding-block) var(--btn-padding-inline);
        background: var(--primary);
        color: var(--text-light);
        border-radius: var(--btn-border-radius);
        font-size: var(--btn-font-size);
        font-weight: var(--btn-font-weight);
        line-height: var(--btn-line-height);
        cursor: pointer;
        transition:
          background var(--transition-duration) var(--transition-timing),
          opacity var(--transition-duration) var(--transition-timing);
      }

      .login__submit:hover {
        background: var(--primary-hover);
      }

      .login__submit:focus-visible {
        outline: var(--focus-width) solid var(--focus-color);
        outline-offset: var(--focus-offset);
      }

      .login__submit:disabled {
        opacity: var(--disabled-opacity);
        cursor: not-allowed;
      }
    }
  </style>

  <script define:vars={{ supabaseUrl, supabaseAnonKey }}>
    if (localStorage.getItem("hour_jwt")) {
      window.location.replace("/difusion");
    }

    const form = document.getElementById("login-form");
    const btn = document.getElementById("submit-btn");
    const errorEl = document.getElementById("error-msg");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.remove("login__error--visible");
      btn.disabled = true;
      btn.textContent = "Entrando...";

      const email = form.email.value.trim();
      const password = form.password.value;

      try {
        const res = await fetch(
          `${supabaseUrl}/auth/v1/token?grant_type=password`,
          {
            method: "POST",
            headers: {
              apikey: supabaseAnonKey,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ email, password }),
          },
        );

        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          throw new Error(
            body.error_description || body.msg || "Credenciales incorrectas",
          );
        }

        const data = await res.json();
        localStorage.setItem("hour_jwt", data.access_token);
        localStorage.setItem("hour_refresh", data.refresh_token);
        localStorage.setItem(
          "hour_expires_at",
          String(Date.now() + data.expires_in * 1000),
        );

        window.location.replace("/difusion");
      } catch (err) {
        errorEl.textContent = err.message;
        errorEl.classList.add("login__error--visible");
        btn.disabled = false;
        btn.textContent = "Entrar";
      }
    });
  </script>
</Base>
